@page "/Login"
@layout NoMenuLayout
@inject NavigationManager Navigation
@inject AuthService AuthService
@inject PasskeyAuthService PasskeyAuthService
@inject DeviceFeedbackService DeviceFeedbackService

<main class="@(navegando ? "saindo" : string.Empty)">
    @if (navegando)
    {
        <div class="loading-overlay">
            <div class="loading-card">
                <img src="~/img/bg-auth-logo.png" alt="Patinhas Magicas" />
                <div class="loading-spinner"></div>
                <p>Preparando sua experiencia...</p>
            </div>
        </div>
    }

    <div id="container-logo">
        <img src="./img/logo-orange.png" alt="Patinhas Mágicas" />
    </div>

    <!-- frase login -->
    <div id="container-frase-login">
        <ul>
            <li>
                <p>Tudo para seu</p>
                <p>Melhor amigo!</p>
            </li>
        </ul>
    </div>

    <!-- login -->
    <div id="container-login">
        <!-- form -->
        <form @onsubmit="FazerLogin" @onsubmit:preventDefault>
            <div class="title">
                <ul>
                    <li>
                        <p>Login</p>
                    </li>
                </ul>
            </div>
            <div class="container-form">
                <ul>
                    <li>
                        <p>Email</p>
                    </li>
                </ul>
                <input @bind="login.Email" placeholder="Email" />
            </div>

            <div class="container-form">
                <ul>
                    <li>
                        <p>Senha</p>
                    </li>
                </ul>
                <input type="password" @bind="login.Senha" placeholder="Senha" />
            </div>

            @if (!string.IsNullOrWhiteSpace(mensagemErro))
            {
                <p class="mensagem-erro">@mensagemErro</p>
            }

            <div class="entrar-recuperar">
                <button type="submit" disabled="@carregando">
                    @(carregando ? "Entrando..." : "Entrar")
                </button>

                @if (biometriaSuportada)
                {
                    <button type="button" class="secondary" @onclick="EntrarComBiometria" disabled="@carregandoBiometria">
                        @(carregandoBiometria ? "Abrindo biometria..." : "Entrar com biometria")
                    </button>
                }

                <a href="#">Recuperar senha</a>
            </div>
        </form>
    </div>
</main>

@code {
    private LoginDTO login = new();
    private string? mensagemErro;
    private bool carregando;
    private bool carregandoBiometria;
    private bool navegando;
    private bool biometriaSuportada;

    protected override async Task OnInitializedAsync()
    {
        biometriaSuportada = await PasskeyAuthService.IsSupportedAsync();
    }

    private async Task FazerLogin()
    {
        if (carregando || carregandoBiometria)
            return;

        mensagemErro = null;
        carregando = true;

        var resultado = await AuthService.Login(login.Email, login.Senha);

        if (resultado.Sucesso)
        {
            await DeviceFeedbackService.VibrateSuccessAsync();
            navegando = true;
            await Task.Delay(450);
            Navigation.NavigateTo("/home");
            return;
        }

        carregando = false;
        mensagemErro = resultado.Mensagem;
        await DeviceFeedbackService.VibrateWarningAsync();
    }

    private async Task EntrarComBiometria()
    {
        if (carregando || carregandoBiometria)
            return;

        mensagemErro = null;
        carregandoBiometria = true;

        var resultado = await PasskeyAuthService.LoginWithPasskeyAsync();

        if (resultado.Sucesso)
        {
            await DeviceFeedbackService.VibrateSuccessAsync();
            navegando = true;
            await Task.Delay(450);
            Navigation.NavigateTo("/home");
            return;
        }

        carregandoBiometria = false;
        mensagemErro = resultado.Mensagem;
        await DeviceFeedbackService.VibrateWarningAsync();
    }
}
