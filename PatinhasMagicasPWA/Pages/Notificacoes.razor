@page "/notificacoes"
@implements IAsyncDisposable
@inject NavigationManager Navigation
@inject NotificationInboxService NotificationInboxService

<main>
    <section class="notifications-hero">
        <div>
            <p class="title">Notificacoes</p>
            <p class="subtitle">Acompanhe seus avisos de agendamento e lembretes importantes.</p>
        </div>

        @if (unreadCount > 0)
        {
            <span class="counter">@unreadCount</span>
        }
    </section>

    <section class="notifications-toolbar">
        <p>@(notifications.Count == 0 ? "Nenhuma notificacao por aqui." : $"{notifications.Count} notificacao(oes) recebida(s).")</p>

        @if (unreadCount > 0)
        {
            <button @onclick="MarcarTodasComoLidasAsync">Marcar tudo como lido</button>
        }
    </section>

    @if (notifications.Count == 0)
    {
        <section class="notifications-empty">
            <span class="material-symbols-outlined">notifications_off</span>
            <p>Quando chegar uma notificacao de agendamento, ela vai aparecer aqui.</p>
        </section>
    }
    else
    {
        <section class="notifications-list">
            @foreach (var notification in notifications)
            {
                <button class="notification-item @(notification.IsRead ? string.Empty : "is-unread")"
                        @onclick="() => AbrirNotificacaoAsync(notification)">
                    <div class="notification-copy">
                        <div class="notification-header">
                            <p class="notification-title">@notification.Title</p>
                            @if (!notification.IsRead)
                            {
                                <span class="unread-dot"></span>
                            }
                        </div>

                        <p class="notification-body">@notification.Body</p>
                        <p class="notification-date">@notification.ReceivedAtUtc.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</p>
                    </div>

                    <span class="material-symbols-outlined">chevron_right</span>
                </button>
            }
        </section>
    }
</main>

<MenuInferior />

@code {
    private List<NotificationInboxItemDTO> notifications = new();
    private int unreadCount;
    private DotNetObjectReference<Notificacoes>? dotNetRef;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        dotNetRef = DotNetObjectReference.Create(this);
        await NotificationInboxService.RegisterListenerAsync(dotNetRef);
        await LoadNotificationsAsync();
        await InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public async Task HandleNotificationInboxChanged()
    {
        await LoadNotificationsAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadNotificationsAsync()
    {
        notifications = await NotificationInboxService.GetAllAsync();
        unreadCount = await NotificationInboxService.GetUnreadCountAsync();
    }

    private async Task MarcarTodasComoLidasAsync()
    {
        await NotificationInboxService.MarkAllAsReadAsync();
        await LoadNotificationsAsync();
    }

    private async Task AbrirNotificacaoAsync(NotificationInboxItemDTO notification)
    {
        if (!notification.IsRead)
        {
            await NotificationInboxService.MarkAsReadAsync(notification.Id);
            await LoadNotificationsAsync();
        }

        if (!string.IsNullOrWhiteSpace(notification.Url))
        {
            Navigation.NavigateTo(notification.Url);
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (dotNetRef is not null)
        {
            await NotificationInboxService.UnregisterListenerAsync(dotNetRef);
            dotNetRef.Dispose();
        }
    }
}
