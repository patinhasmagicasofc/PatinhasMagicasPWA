@page "/perfil/configuracoes"
@inject JwtService JwtService
@inject PushNotificationService PushNotificationService
@inject DeviceFeedbackService DeviceFeedbackService
@inject PasskeyAuthService PasskeyAuthService

<main>
    <section class="settings-hero">
        <p class="title">Configuracoes</p>
        <p class="subtitle">Centralize avisos, acessos do dispositivo e seguranca da conta em um unico lugar.</p>
    </section>

    <section class="settings-card">
        <p class="section-title">Notificacoes push</p>
        <p class="section-text">Ative para receber confirmacoes de agendamento e avisos importantes.</p>

        <button type="button"
                class="switch-row"
                role="switch"
                aria-checked="@pushEnabled"
                @onclick="TogglePushAsync"
                disabled="@loading">
            <span class="switch-copy">
                <span class="switch-title">Receber notificacoes</span>
                <span class="helper-text">@GetPushStatusText()</span>
            </span>
            <span class="switch @(pushEnabled ? "is-on" : string.Empty)">
                <span class="switch-thumb"></span>
            </span>
        </button>

        @if (!string.IsNullOrWhiteSpace(pushMessage))
        {
            <p class="feedback">@pushMessage</p>
        }

        <div class="button-group">
            <button class="secondary" @onclick="EnviarTestePushAsync" disabled="@loading">
                <span class="material-symbols-outlined">send</span>
                Enviar teste push
            </button>
        </div>
    </section>

    <section class="settings-card">
        <p class="section-title">Feedback por vibracao</p>
        <p class="section-text">Use vibracao curta em confirmacoes, erro ou acoes importantes no celular.</p>

        <button type="button"
                class="switch-row"
                role="switch"
                aria-checked="@vibrationEnabled"
                @onclick="ToggleVibrationAsync"
                disabled="@(!deviceSupported)">
            <span class="switch-copy">
                <span class="switch-title">Vibracao do app</span>
                <span class="helper-text">@GetVibrationStatusText()</span>
            </span>
            <span class="switch @(vibrationEnabled ? "is-on" : string.Empty)">
                <span class="switch-thumb"></span>
            </span>
        </button>

        @if (!string.IsNullOrWhiteSpace(deviceMessage))
        {
            <p class="feedback">@deviceMessage</p>
        }

        <div class="button-group">
            <button class="primary" @onclick="TestarVibracaoSucessoAsync" disabled="@(!deviceSupported)">
                <span class="material-symbols-outlined">done_all</span>
                Testar sucesso
            </button>

            <button class="secondary" @onclick="TestarVibracaoAvisoAsync" disabled="@(!deviceSupported)">
                <span class="material-symbols-outlined">warning</span>
                Testar aviso
            </button>
        </div>

        <p class="helper-text">Vibracao disponivel: @(deviceSupported ? "Sim" : "Nao")</p>
    </section>

    <section class="settings-card">
        <p class="section-title">Biometria e passkeys</p>
        <p class="section-text">Cadastre uma passkey para entrar com digital, rosto ou PIN do dispositivo.</p>
        <p class="helper-text">Suporte no navegador: @(passkeySupported ? "Sim" : "Nao")</p>

        @if (!string.IsNullOrWhiteSpace(passkeyMessage))
        {
            <p class="feedback">@passkeyMessage</p>
        }

        <div class="button-group">
            <button class="primary" @onclick="CadastrarBiometriaAsync" disabled="@(!passkeySupported || loading)">
                <span class="material-symbols-outlined">fingerprint</span>
                @(loading ? "Abrindo biometria..." : "Cadastrar neste dispositivo")
            </button>
        </div>

        <div class="credential-list">
            @if (credenciais.Count == 0)
            {
                <p class="section-text">Nenhuma biometria cadastrada ainda.</p>
            }
            else
            {
                @foreach (var credencial in credenciais)
                {
                    <div class="credential-item">
                        <div class="credential-copy">
                            <p class="section-text">@credencial.FriendlyName</p>
                            <p class="helper-text">Criado em @credencial.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</p>
                            @if (credencial.LastUsedAt.HasValue)
                            {
                                <p class="helper-text">Ultimo uso em @credencial.LastUsedAt.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</p>
                            }
                        </div>

                        <button class="secondary" @onclick="() => RemoverBiometriaAsync(credencial.Id)" disabled="@loading">
                            Remover
                        </button>
                    </div>
                }
            }
        </div>
    </section>
</main>

<MenuInferior />

@code {
    private string pushMessage = string.Empty;
    private string deviceMessage = string.Empty;
    private string? passkeyMessage;
    private bool loading;
    private int? usuarioId;
    private bool deviceSupported;
    private bool vibrationEnabled = true;
    private bool pushEnabled;
    private bool passkeySupported;
    private List<PasskeyCredentialDTO> credenciais = new();

    protected override async Task OnInitializedAsync()
    {
        var userIdString = await JwtService.GetUserIdAsync();
        usuarioId = int.TryParse(userIdString, out var userId) ? userId : null;

        try
        {
            deviceSupported = await DeviceFeedbackService.IsSupportedAsync();
            vibrationEnabled = await DeviceFeedbackService.IsEnabledAsync();
        }
        catch
        {
            deviceSupported = false;
            vibrationEnabled = false;
        }

        try
        {
            pushEnabled = await PushNotificationService.IsEnabledAsync();
            passkeySupported = await PasskeyAuthService.IsSupportedAsync();
            credenciais = await PasskeyAuthService.GetMyCredentialsAsync();
        }
        catch
        {
            pushEnabled = false;
            passkeySupported = false;
            credenciais = new();
        }
    }

    private async Task TogglePushAsync()
    {
        if (!usuarioId.HasValue)
        {
            pushMessage = "Usuario nao identificado.";
            await DeviceFeedbackService.VibrateWarningAsync();
            return;
        }

        loading = true;

        try
        {
            var result = pushEnabled
                ? await PushNotificationService.DisableAsync()
                : await PushNotificationService.SubscribeAsync(usuarioId.Value);

            pushMessage = result.Message;
            pushEnabled = result.Success
                ? !pushEnabled
                : pushEnabled;

            if (result.Success)
            {
                await DeviceFeedbackService.VibrateSuccessAsync();
                return;
            }

            await DeviceFeedbackService.VibrateWarningAsync();
        }
        finally
        {
            loading = false;
        }
    }

    private async Task ToggleVibrationAsync()
    {
        if (!deviceSupported)
        {
            return;
        }

        vibrationEnabled = !vibrationEnabled;
        await DeviceFeedbackService.SetEnabledAsync(vibrationEnabled);
        deviceMessage = vibrationEnabled
            ? "Vibracao ativada para este dispositivo."
            : "Vibracao desativada para este dispositivo.";

        if (vibrationEnabled)
        {
            await DeviceFeedbackService.VibrateSuccessAsync();
        }
    }

    private async Task EnviarTestePushAsync()
    {
        if (!usuarioId.HasValue)
        {
            pushMessage = "Usuario nao identificado.";
            await DeviceFeedbackService.VibrateWarningAsync();
            return;
        }

        loading = true;

        try
        {
            var result = await PushNotificationService.SendTestAsync(usuarioId.Value);
            pushMessage = result.Message;

            if (result.Success)
            {
                await DeviceFeedbackService.VibrateSuccessAsync();
                return;
            }

            await DeviceFeedbackService.VibrateWarningAsync();
        }
        finally
        {
            loading = false;
        }
    }

    private async Task TestarVibracaoSucessoAsync()
    {
        var supported = await DeviceFeedbackService.IsSupportedAsync();
        deviceMessage = supported
            ? "Feedback de sucesso disparado."
            : "Seu dispositivo ou navegador nao oferece suporte a vibracao.";

        if (supported)
        {
            await DeviceFeedbackService.VibrateSuccessAsync();
        }
    }

    private async Task TestarVibracaoAvisoAsync()
    {
        var supported = await DeviceFeedbackService.IsSupportedAsync();
        deviceMessage = supported
            ? "Feedback de aviso disparado."
            : "Seu dispositivo ou navegador nao oferece suporte a vibracao.";

        if (supported)
        {
            await DeviceFeedbackService.VibrateWarningAsync();
        }
    }

    private async Task CadastrarBiometriaAsync()
    {
        loading = true;
        passkeyMessage = null;

        try
        {
            var resultado = await PasskeyAuthService.RegisterCurrentDeviceAsync();
            passkeyMessage = resultado.Message;

            if (resultado.Success)
            {
                await DeviceFeedbackService.VibrateSuccessAsync();
                await CarregarCredenciaisAsync();
            }
            else
            {
                await DeviceFeedbackService.VibrateWarningAsync();
            }
        }
        finally
        {
            loading = false;
        }
    }

    private async Task RemoverBiometriaAsync(int credentialId)
    {
        loading = true;
        passkeyMessage = null;

        try
        {
            var resultado = await PasskeyAuthService.RemoveCredentialAsync(credentialId);
            passkeyMessage = resultado.Message;

            if (resultado.Success)
            {
                await DeviceFeedbackService.VibrateSuccessAsync();
                await CarregarCredenciaisAsync();
            }
            else
            {
                await DeviceFeedbackService.VibrateWarningAsync();
            }
        }
        finally
        {
            loading = false;
        }
    }

    private async Task CarregarCredenciaisAsync()
    {
        credenciais = await PasskeyAuthService.GetMyCredentialsAsync();
    }

    private string GetPushStatusText()
    {
        return pushEnabled
            ? "Ligado neste dispositivo"
            : "Desligado neste dispositivo";
    }

    private string GetVibrationStatusText()
    {
        if (!deviceSupported)
        {
            return "Seu dispositivo nao oferece suporte";
        }

        return vibrationEnabled
            ? "Ligado neste dispositivo"
            : "Desligado neste dispositivo";
    }
}
