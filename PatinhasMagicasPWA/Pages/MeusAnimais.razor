@page "/MeusAnimais"
@inject AnimalService AnimalService
@inject NavigationManager Navigation

<main>
    <div class="btn-novo-animal">
        <p>Cadastre um novo animal</p>
        <button @onclick="CadastrarAnimal">Cadastrar animal</button>
    </div>

    @if (isLoading)
    {
        <section class="loading-stack" aria-label="Carregando animais">
            @for (var index = 0; index < 3; index++)
            {
                <div class="loading-card">
                    <div class="loading-row space-between">
                        <div class="loading-row">
                            <div class="loading-circle"></div>
                            <div class="loading-copy">
                                <div class="loading-line md"></div>
                                <div class="loading-line sm"></div>
                                <div class="loading-line sm"></div>
                            </div>
                        </div>
                        <div class="loading-pill"></div>
                    </div>
                </div>
            }
        </section>
    }
    else if (animals.Count == 0)
    {
        <p>Você ainda não tem animais cadastrados.</p>
    }
    else if (animals.Count > 0)
    {
        @foreach (var animal in animals)
        {

            <div class="menu-card">

                <div class="info">
                    <img src="@(string.IsNullOrWhiteSpace(animal.FotoDataUrl) ? "./img/grooming-dog.jpg" : animal.FotoDataUrl)" alt="Animal">
                    <ul>
                        <li>
                            <p>@animal.Nome</p>
                            <p>@animal.NomeEspecie</p>
                            <p>@animal.Idade</p>
                        </li>
                    </ul>


                </div>
                <button @onclick="() => VerDetalhes(animal.Id)">Ver detalhes</button>
            </div>
        }
    }

</main>

@code {
    List<AnimalDTO> animals = new();
    bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            animals = await AnimalService.GetAllAnimalsAsync();
        }
        finally
        {
            isLoading = false;
        }
    }

    private Task VerDetalhes(int id)
    {
        Navigation.NavigateTo($"/animal/{id}");
        return Task.CompletedTask;
    }

    private Task CadastrarAnimal()
    {
        Navigation.NavigateTo("/CadastroAnimal");
        return Task.CompletedTask;
    }
}
