@page "/MeusAgendamentos"
@inject NavigationManager Navigation
@inject AgendamentoService AgendamentoService

<main>
    <div class="btn-novo-agendamento">
        <p>Seu pet merece esse cuidado 🐾</p>
        <button @onclick="Agendar">Agendar agora</button>
    </div>

    @if (isLoading)
    {
        <section class="loading-stack" aria-label="Carregando agendamentos">
            @for (var index = 0; index < 3; index++)
            {
                <div class="loading-card">
                    <div class="loading-row">
                        <div class="loading-circle"></div>
                        <div class="loading-copy">
                            <div class="loading-row space-between">
                                <div class="loading-line md"></div>
                                <div class="loading-pill"></div>
                            </div>
                            <div class="loading-line lg"></div>
                            <div class="loading-line sm"></div>
                        </div>
                    </div>
                </div>
            }
        </section>
    }
    else if (agendamentos.Count == 0)
    {
        <div class="info-bg-service">
            <ul>
                <li>
                    <p>Você não tem agendamento ativo no momento.</p>
                </li>
            </ul>
        </div>
    }
    else
    {
        <div class="info-bg-service">
            <ul>
                <li>
                    <p>Seus agendamentos e serviços ativos:</p>
                </li>
            </ul>
        </div>

        @foreach (var agendamento in agendamentos)
        {
            <div class="card-service">
                <div class="icon-details">
                    <div class="icon-service">
                        <span class="material-symbols-outlined">bathtub</span>
                    </div>
                    <div class="details-service">
                        <div class="status-serviceType">
                            <ul>
                                <li>
                                    <p class="type-service-card">@agendamento.Servicos.FirstOrDefault()?.Nome</p>
                                </li>

                                <li class="status-service">
                                    <p class="status--@agendamento.Status.SemAcento().ToLower()">
                                        @agendamento.Status
                                    </p>
                                </li>
                            </ul>
                        </div>
                        <div class="info-service">
                            <ul>
                                <li>
                                    <p>Animal: @agendamento.Animal?.Nome</p>
                                    <p>
                                        Data: @agendamento.DataAgendamento.ToString("dd/MM/yyyy, HH:mm")
                                    </p>
                                </li>
                            </ul>
                        </div>
                    </div>
                </div>

                <div class="btn-service">
                    <button @onclick="() => VerDetalhes(agendamento.Id)">Ver detalhes</button>
                </div>
            </div>
        }

    }

    <MenuInferior />

</main>
@code {

    List<AgendamentoDTO> agendamentos = new();
    bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            agendamentos = await AgendamentoService.GetAll() ?? new List<AgendamentoDTO>();
        }
        finally
        {
            isLoading = false;
        }
    }

    private void VerDetalhes(int id)
    {
        Navigation.NavigateTo($"/agendamento/{id}");
    }

    private void Agendar()
    {
        Navigation.NavigateTo($"/agendamentoServico/");
    }

}
