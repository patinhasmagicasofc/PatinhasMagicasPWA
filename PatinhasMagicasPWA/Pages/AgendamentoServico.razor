@page "/agendamentoServico"
@inject NavigationManager Navigation
@inject AnimalService AnimalService
@inject ServicoService ServicoService
@inject AgendamentoService AgendamentoService
@inject DeviceFeedbackService DeviceFeedbackService

<main id="agendamento-servico">

<div id="card-form">
        <EditForm Model="@agendamento"
                  OnValidSubmit="Pagamento">
            <DataAnnotationsValidator />
            <ul>
                <li>
                    <p class="title">Agendamento de Serviços</p>
                </li>
            </ul>

            <div class="field">
                <ul>
                    <li>
                        <InputSelect @bind-Value="selectedAnimalId"
                                     class="input-select"
                                     disabled="@isLoadingAnimals"
                                     required>
                            <option value="">Selecione um animal</option>
                            @if (isLoadingAnimals)
                            {
                                <option disabled>Carregando animais...</option>
                            }
                            else if (!string.IsNullOrWhiteSpace(loadAnimalsError))
                            {
                                <option disabled>@loadAnimalsError</option>
                            }
                            else if (animals.Count == 0)
                            {
                                <option disabled>Não há animais cadastrados</option>
                            }
                            else
                            {
                                @foreach (var animal in animals)
                                {
                                    <option value="@animal.Id">
                                        @animal.Nome (@animal.NomeEspecie - @animal.NomeTamanhoAnimal)
                                    </option>
                                }
                            }
                        </InputSelect>
                        <ValidationMessage class="text-danger" For="@(() => agendamento.AnimalId)" />
                    </li>
                </ul>
            </div>

        <div class="field">
            <ul>
                <li>
                    <InputSelect class="input-select"
                                 @bind-Value="selectedServicoId"
                                 disabled="@(!(selectedAnimalId > 0))"
                                 required>
                        <option value="">Selecione o Serviço</option>
                        @if (!(selectedAnimalId > 0))
                        {
                            <option disabled>Selecione o animal primeiro</option>
                        }
                        else if (servicos.Count == 0)
                        {
                            <option disabled>Não há serviços disponíveis para este animal</option>
                        }
                        else
                        {
                            @foreach (var servico in servicos)
                            {
                                <option value="@(servico.Id ?? 0)">
                                    @servico.Nome - R$ @String.Format("{0:0.00}", servico.Preco)
                                </option>
                            }
                        }
                    </InputSelect>
                    <ValidationMessage class="text-danger" For="@(() => agendamento.ServicoId)" />
                </li>
            </ul>
        </div>

            <div class="field">
                <ul>
                    <li>
                        <label>Data e Hora</label>
                        <InputDate @bind-Value="agendamento.DataAgendamento"
                                   Type="InputDateType.DateTimeLocal"
                                   id="dataAgendamento"
                                   class="input-real" 
                                   required />
                        <ValidationMessage class="text-danger" For="@(() => agendamento.DataAgendamento)" />
                    </li>
                </ul>
            </div>
            
            <div class="actions">
                <button class="btn-primary" type="submit">Avançar</button>
            
            </div>
            <div class="field">
                <ul>
                    <li>
                        <button type="button" class="btn-secondary" @onclick="CadastrarAnimal">Cadastrar Animal</button>
                    </li>
                </ul>
            </div>

           
        </EditForm>
</div>
    
</main>

@code {
    AgendamentoFluxoDTO agendamento = new();
    List<AnimalSelectOptionDTO> animals = new();
    List<ServicoOutputDTO> servicos = new();
    bool isLoadingAnimals = true;
    string? loadAnimalsError;

    private int? _selectedAnimalId;
    private int? _selectedServicoId;

    int? selectedAnimalId
    {
        get => _selectedAnimalId;
        set
        {
            if (_selectedAnimalId != value)
            {
                var hadPreviousSelection = _selectedAnimalId.HasValue;
                _selectedAnimalId = value;
                agendamento.AnimalId = value ?? 0;
                if (value.HasValue && hadPreviousSelection)
                {
                    _ = DeviceFeedbackService.VibrateSelectionAsync();
                }
                _ = OnAnimalChangedAsync();
            }
        }
    }

    int? selectedServicoId
    {
        get => _selectedServicoId;
        set
        {
            var changed = _selectedServicoId != value;
            _selectedServicoId = value;
            agendamento.ServicoId = value ?? 0;
            if (changed && value.HasValue)
            {
                _ = DeviceFeedbackService.VibrateSelectionAsync();
            }
        }
    }

    protected override void OnInitialized()
    {
        selectedAnimalId = null;
        selectedServicoId = null;
        servicos.Clear();
        _ = LoadAnimalsAsync();
    }

    private async Task LoadAnimalsAsync()
    {
        var cachedAnimals = await AnimalService.GetCachedAnimalOptionsAsync();
        if (cachedAnimals.Count > 0)
        {
            animals = cachedAnimals;
            isLoadingAnimals = false;
            await InvokeAsync(StateHasChanged);
        }

        try
        {
            isLoadingAnimals = true;
            loadAnimalsError = null;
            animals = await AnimalService.GetAnimalOptionsAsync(forceRefresh: cachedAnimals.Count > 0);
        }
        catch
        {
            animals = new();
            loadAnimalsError = "Erro ao carregar animais";
        }
        finally
        {
            isLoadingAnimals = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task OnAnimalChangedAsync()
    {
        if (isLoadingAnimals)
        {
            return;
        }

        // tenta obter os serviços já com o preço de acordo com o porte/id do animal
        if (selectedAnimalId > 0)
        {
            var porAnimal = await ServicoService.GetServicosPorAnimalAsync(selectedAnimalId.Value);
            if (porAnimal != null)
            {
                servicos = porAnimal;
                // mantém o placeholder selecionado até o usuário escolher um serviço
                selectedServicoId = null;

                await InvokeAsync(StateHasChanged);
            }
            else
            {
                servicos.Clear();
                selectedServicoId = null;
                await InvokeAsync(StateHasChanged);
            }
        }
        else
        {
            servicos.Clear();
            selectedServicoId = null;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void Voltar()
    {
        Navigation.NavigateTo("/home");
    }

    private void CadastrarAnimal()
    {
        Navigation.NavigateTo("/CadastroAnimal");
    }

    private void AgendarServico()
    {
        Navigation.NavigateTo("/ServicoConfirmacao");
    }

    private async Task Pagamento()
    {
        // navega para a tela de pagamento carregando os dados selecionados
        var dataEncoded = agendamento.DataAgendamento.HasValue ? Uri.EscapeDataString(agendamento.DataAgendamento.Value.ToString("s")) : string.Empty;
        await DeviceFeedbackService.VibrateSelectionAsync();
        Navigation.NavigateTo($"/pagamento?animalId={selectedAnimalId ?? 0}&servicoId={selectedServicoId ?? 0}&data={dataEncoded}");
    }

}
