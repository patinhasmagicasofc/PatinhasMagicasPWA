@page "/perfil"
@inject NavigationManager Navigation
@inject JwtService JwtService
@inject UsuarioService UsuarioService
@inject AuthService AuthService

<main>
    @if (isLoading)
    {
        <section class="loading-profile-card" aria-label="Carregando perfil">
            <div class="loading-avatar"></div>
            <div class="loading-copy">
                <div class="loading-line md"></div>
                <div class="loading-line sm"></div>
            </div>
        </section>

        <section class="loading-stack">
            @for (var index = 0; index < 5; index++)
            {
                <div class="loading-card">
                    <div class="loading-row">
                        <div class="loading-circle"></div>
                        <div class="loading-line full"></div>
                    </div>
                </div>
            }
        </section>
    }
    else if (usuario is null)
    {
        <p>Nao foi possivel carregar seu perfil.</p>
    }
    else
    {
        <section class="profile-header">
            <div class="avatar"><img src="./img/hero-pets.jpg" alt=""></div>
            <p>@usuario.Nome</p>
            <p>@usuario.Email</p>
        </section>

        <section class="profile-menu">
            <div class="menu-item">
                <button @onclick="IrParaEditar">
                    <span class="material-symbols-outlined">person</span>
                    Alterar dados do perfil
                </button>
            </div>

            <div class="menu-item">
                <button @onclick="IrParaMeusAnimais">
                    <span class="material-symbols-outlined">pets</span>
                    Seus animais cadastrados
                </button>
            </div>

            <div class="menu-item">
                <button>
                    <span class="material-symbols-outlined">shopping_bag</span>
                    Meus pedidos
                </button>
            </div>

            <div class="menu-item">
                <button>
                    <span class="material-symbols-outlined">favorite</span>
                    Favoritos
                </button>
            </div>

            <div class="menu-item">
                <button>
                    <span class="material-symbols-outlined">support_agent</span>
                    Suporte
                </button>
            </div>

            <div class="menu-item">
                <button @onclick="IrParaConfiguracoes">
                    <span class="material-symbols-outlined">settings</span>
                    Configuracoes
                </button>
            </div>
        </section>

        <section class="profile-actions">
            <button class="logout-button" @onclick="SairAsync">
                <span class="material-symbols-outlined">logout</span>
                Sair da conta
            </button>
        </section>
    }
</main>

<MenuInferior />

@code {
    private UsuarioOutputDTO? usuario;
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var userIdString = await JwtService.GetUserIdAsync();

            if (!int.TryParse(userIdString, out var userId))
            {
                Navigation.NavigateTo("/Login", replace: true);
                return;
            }

            usuario = await UsuarioService.GetByIdAsync(userId);

            if (usuario is null)
            {
                Navigation.NavigateTo("/Login", replace: true);
            }
        }
        finally
        {
            isLoading = false;
        }
    }

    private void IrParaEditar()
    {
        Navigation.NavigateTo("/perfil/editar");
    }

    private void IrParaMeusAnimais()
    {
        Navigation.NavigateTo("/meusanimais");
    }

    private void IrParaConfiguracoes()
    {
        Navigation.NavigateTo("/perfil/configuracoes");
    }

    private async Task SairAsync()
    {
        await AuthService.Logout();
        Navigation.NavigateTo("/Login", replace: true);
    }
}
